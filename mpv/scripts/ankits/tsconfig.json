{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // https://stackoverflow.com/questions/42984889/global-types-in-typescript
    "paths": {
      "*": ["./types/*.d.ts"],
    },
    "target": "esnext",
    "module": "esnext",
    "rootDir": "./src/",
    "outDir": "./out/js/",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "lib": [
      "ES5",
      "ES2015.Promise"
    ],
  },
}
